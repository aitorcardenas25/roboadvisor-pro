# ============================================================
# RoboAdvisor Pro — Variables d'entorn
# Copia aquest fitxer com .env.local i omple els valors reals
# IMPORTANT: NO commitegis mai .env.local al repositori!
# ============================================================

# ── AUTENTICACIÓ (obligatori) ─────────────────────────────────────────────────

# Administrador principal
ADMIN_USERNAME=admin
ADMIN_PASSWORD=canvia-per-una-contrasenya-segura-aqui!
ADMIN_EMAIL=admin@elteudominiovericat.com

# Usuaris autoritzats addicionals (JSON array, opcional)
# Rols disponibles: 'authorized' (cartera pròpia), 'admin' (accés total)
# Exemple:
# AUTHORIZED_USERS=[{"username":"usuari1","password":"pass1","name":"Nom Cognom","email":"u1@ex.com","role":"authorized","active":true}]
AUTHORIZED_USERS=

# Secret per a JWT/NextAuth (genera-la amb: openssl rand -base64 32)
NEXTAUTH_SECRET=GENERA_UN_SECRET_LLARG_I_ALEATORI_AQUI

# URL de l'aplicació (ajusta per a producció)
NEXTAUTH_URL=http://localhost:3000

# ── APIs FINANCERES (opcional per a dades reals) ──────────────────────────────

# ── CADENA DE FONTS (FMP → Alpha Vantage → Yahoo → Simulat) ──────────────────
#
# [1] Financial Modeling Prep (FMP) — RECOMANAT, cobertura europea
# Pla gratuït: 250 crides/dia · https://financialmodelingprep.com/
FMP_API_KEY=

# [2] Alpha Vantage — alternativa per a ETFs USA i dades macro
# Pla gratuït: 25 crides/dia · https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# [3] Yahoo Finance — fallback automàtic, sense clau, limit no oficial
# No cal cap variable. El servidor la crida directament (server-side only).

# ── APIS NO VIABLES SENSE SUBSCRIPCIÓ ────────────────────────────────────────
#
# TradingView: NO té API pública per a dades de preus. Ofereix widgets
#   d'embedding (iframe) que es poden afegir al frontend com a component visual,
#   però NO es pot consumir programàticament. Servei preparat per a widget:
#   afegeix <script src="https://s3.tradingview.com/tv.js"></script> al component.
#   No cal cap API key.
#
# Investing.com: NO té API pública oficial. L'scraping directe viola els seus
#   Termes de Servei. No és viable com a font de dades.
#
# Per a gràfics premium amb TradingView widgets al comparador, configura:
TRADINGVIEW_WIDGET_ENABLED=false
# Si true, el comparador mostrarà el widget TradingView en lloc del gràfic propi.

# Open Exchange Rates — tipus de canvi opcionals
# https://openexchangerates.org/signup
OPEN_EXCHANGE_RATES_APP_ID=

# ── EMAIL (opcional per a enviament d'informes) ───────────────────────────────

# Resend - servei d'enviament d'emails transaccionals
# Registre a: https://resend.com (pla gratuït: 100 emails/dia)
RESEND_API_KEY=

# Email remitent configurat a Resend (ha de ser un domini verificat)
RESEND_FROM_EMAIL=informes@elteudominiovericat.com

# ── CONFIGURACIÓ OPCIONAL ─────────────────────────────────────────────────────

# Entorn de l'aplicació
NODE_ENV=development

# Activa/desactiva el mode de dades simulades (per defecte: true quan no hi ha APIs)
# Si és false i no hi ha API keys, el backtest fallarà
USE_SIMULATED_DATA=true

# Número de simulacions Monte Carlo (default: 1000, màxim recomanat: 5000)
MONTE_CARLO_SIMULATIONS=1000

# Tipus lliure de risc (% anual, default: 3.0 = tipus BCE aproximat)
RISK_FREE_RATE=3.0

# ── INSTRUCCIONS ──────────────────────────────────────────────────────────────
#
# 1. MÍNIM necessari per funcionar en local:
#    - Omple ADMIN_USERNAME, ADMIN_PASSWORD i NEXTAUTH_SECRET
#    - Les dades financeres seran simulades (suficient per al TFG)
#
# 2. Per a dades financeres REALS:
#    - Afegeix FMP_API_KEY (recomanat) o ALPHA_VANTAGE_API_KEY
#    - Els fons amb ISIN europeus no sempre estan disponibles a Yahoo Finance
#    - FMP cobreix millor fons europeus; Alpha Vantage cobreix bé ETFs USA
#
# 3. Per a enviament d'informes per EMAIL:
#    - Registra't a Resend.com i verifica el teu domini
#    - Afegeix RESEND_API_KEY i RESEND_FROM_EMAIL
#
# 4. Seguretat:
#    - Canvia SEMPRE les credencials per defecte en producció
#    - El fitxer .env.local ja està inclòs al .gitignore
#    - MAI exposis claus API al codi frontend (usa sempre API Routes de Next.js)
#
# ─────────────────────────────────────────────────────────────────────────────
